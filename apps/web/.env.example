# Jornada Leve — Variáveis de Ambiente

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Criptografia de observações de check-in (32+ caracteres recomendado) ---
CHECKIN_NOTES_ENCRYPTION_KEY=

# --- Resend (Email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Jornada Leve <nao-responda@seudominio.com.br>

# --- Efí (Pagamentos; somente servidor) ---
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_SANDBOX=true
EFI_WEBHOOK_TOKEN=
# IDs de planos previamente criados na Efí (opcionais; se vazios, a API cria o plano)
EFI_MONTHLY_PLAN_ID=
EFI_ANNUAL_PLAN_ID=

# --- Vercel Cron / Dunning (16+ caracteres) ---
CRON_SECRET=

# --- Sentry (Opcional) ---
SENTRY_DSN=
